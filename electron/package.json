{
  "name": "synchire-desktop",
  "version": "1.0.0",
  "description": "SyncHire - AI-Powered Job Application Tool",
  "main": "main.js",
  "author": "SyncHire",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env ELECTRON_DEV=true electron .",
    "build": "echo 'Build handled by electron-builder'",
    "package:win": "electron-builder --win --config electron-builder.yml",
    "package:mac": "electron-builder --mac --config electron-builder.yml",
    "package:linux": "electron-builder --linux --config electron-builder.yml",
    "package:all": "electron-builder --win --mac --linux --config electron-builder.yml"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "cross-env": "^7.0.3"
  },
  "build": {
    "appId": "com.synchire.desktop",
    "productName": "SyncHire",
    "files": [
      "main.js",
      "preload.js",
      "frontend/out/**/*",
      "python/**/*"
    ]
  }
}
