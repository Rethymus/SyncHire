"use client";

import { useState } from "react";
import {
  Dialog,
  DialogContent,
  DialogDescription,
  DialogFooter,
  DialogHeader,
  DialogTitle,
} from "@/components/ui/dialog";
import { Button } from "@/components/ui/button";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import { Label } from "@/components/ui/label";
import { RadioGroup, RadioGroupItem } from "@/components/ui/radio-group";
import { Download, Loader2, AlertCircle } from "lucide-react";

const TEMPLATES = [
  {
    id: "minimal",
    name: "简约风格",
    description: "简洁单栏，ATS友好设计",
    englishName: "Minimal",
  },
  {
    id: "professional",
    name: "商务风格",
    description: "双栏布局，侧边栏设计",
    englishName: "Professional",
  },
  {
    id: "creative",
    name: "创意风格",
    description: "现代设计，强调色搭配",
    englishName: "Creative",
  },
  {
    id: "executive",
    name: "高管风格",
    description: "保守设计，适合高级职位",
    englishName: "Executive",
  },
];

interface ResumeExportDialogProps {
  open: boolean;
  onOpenChange: (open: boolean) => void;
  resumeId: string;
  resumeName: string;
}

export function ResumeExportDialog({
  open,
  onOpenChange,
  resumeId,
  resumeName,
}: ResumeExportDialogProps) {
  const [template, setTemplate] = useState("minimal");
  const [dpi, setDpi] = useState("300");
  const [isExporting, setIsExporting] = useState(false);
  const [exportAll, setExportAll] = useState(false);
  const [error, setError] = useState<string | null>(null);

  const handleExport = async () => {
    setIsExporting(true);

    try {
      if (exportAll) {
        // 导出所有模板为 ZIP
        const response = await fetch(
          `/api/resumes/${resumeId}/export/batch`,
          {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              templates: TEMPLATES.map((t) => t.id),
            }),
          }
        );

        if (!response.ok) throw new Error("导出失败");

        const blob = await response.blob();
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `${resumeName}_全部模板.zip`;
        document.body.appendChild(a);
        a.click();
        window.URL.revokeObjectURL(url);
        document.body.removeChild(a);
      } else {
        // 导出单个模板
        const response = await fetch(`/api/resumes/${resumeId}/export`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            template,
            dpi: parseInt(dpi),
          }),
        });

        if (!response.ok) throw new Error("导出失败");

        const blob = await response.blob();
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `${resumeName}_${template}_简历.pdf`;
        document.body.appendChild(a);
        a.click();
        window.URL.revokeObjectURL(url);
        document.body.removeChild(a);
      }

      onOpenChange(false);
      setError(null);
    } catch (error) {
      console.error("导出错误:", error);
      setError("导出失败，请稍后重试。如果问题持续存在，请检查网络连接。");
    } finally {
      setIsExporting(false);
    }
  };

  return (
    <Dialog open={open} onOpenChange={onOpenChange}>
      <DialogContent className="sm:max-w-[500px]">
        <DialogHeader>
          <DialogTitle>导出简历为 PDF</DialogTitle>
          <DialogDescription>
            为您的 PDF 导出选择模板和质量设置
          </DialogDescription>
        </DialogHeader>

        {error && (
          <div className="bg-red-50 border border-red-200 rounded-lg p-3 flex items-start gap-2">
            <AlertCircle className="h-5 w-5 text-red-600 flex-shrink-0 mt-0.5" />
            <p className="text-sm text-red-800">{error}</p>
          </div>
        )}

        <div className="space-y-6 py-4">
          {/* 模板选择 */}
          <div className="space-y-2">
            <Label htmlFor="template-select">模板选择</Label>
            <Select value={template} onValueChange={(value) => { setTemplate(value); setError(null); }}>
              <SelectTrigger id="template-select">
                <SelectValue placeholder="选择一个模板" />
              </SelectTrigger>
              <SelectContent>
                {TEMPLATES.map((t) => (
                  <SelectItem key={t.id} value={t.id}>
                    <div>
                      <div className="font-medium">{t.name}</div>
                      <div className="text-xs text-muted-foreground">
                        {t.description}
                      </div>
                    </div>
                  </SelectItem>
                ))}
              </SelectContent>
            </Select>
          </div>

          {/* 质量/DPI 选择 */}
          <div className="space-y-2">
            <Label>导出质量 (DPI)</Label>
            <RadioGroup value={dpi} onValueChange={setDpi}>
              <div className="flex items-center space-x-2">
                <RadioGroupItem value="150" id="dpi-150" />
                <Label htmlFor="dpi-150" className="font-normal cursor-pointer">
                  屏幕查看 (150 DPI) - 文件最小
                </Label>
              </div>
              <div className="flex items-center space-x-2">
                <RadioGroupItem value="300" id="dpi-300" />
                <Label htmlFor="dpi-300" className="font-normal cursor-pointer">
                  打印质量 (300 DPI) - 推荐
                </Label>
              </div>
              <div className="flex items-center space-x-2">
                <RadioGroupItem value="600" id="dpi-600" />
                <Label htmlFor="dpi-600" className="font-normal cursor-pointer">
                  高质量 (600 DPI) - 文件最大
                </Label>
              </div>
            </RadioGroup>
          </div>

          {/* 导出全部选项 */}
          <div className="flex items-center space-x-2">
            <input
              type="checkbox"
              id="export-all"
              checked={exportAll}
              onChange={(e) => setExportAll(e.target.checked)}
              className="rounded"
            />
            <Label htmlFor="export-all" className="font-normal cursor-pointer">
              导出所有模板为 ZIP 文件
            </Label>
          </div>
        </div>

        <DialogFooter>
          <Button
            variant="outline"
            onClick={() => onOpenChange(false)}
            disabled={isExporting}
          >
            取消
          </Button>
          <Button onClick={handleExport} disabled={isExporting}>
            {isExporting ? (
              <>
                <Loader2 className="mr-2 h-4 w-4 animate-spin" />
                导出中...
              </>
            ) : (
              <>
                <Download className="mr-2 h-4 w-4" />
                导出 PDF
              </>
            )}
          </Button>
        </DialogFooter>
      </DialogContent>
    </Dialog>
  );
}
