# Database
POSTGRES_USER=synchire
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=synchire
DATABASE_URL=postgresql://synchire:your_secure_password_here@localhost:5432/synchire

# Redis
REDIS_URL=redis://localhost:6379
REDIS_RATE_LIMIT_WINDOW=60
REDIS_RATE_LIMIT_MAX_REQUESTS=100

# Minio (S3-compatible storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_secure_minio_password
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your_secure_minio_password
MINIO_USE_SSL=false
MINIO_BUCKET_RESUMES=synchire-resumes
MINIO_BUCKET_JDS=synchire-jds

# AI APIs
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# JWT Authentication
JWT_SECRET=your_jwt_secret_generate_with_openssl_rand_base64_32
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Application
NODE_ENV=development
API_PORT=8000
FRONTEND_PORT=3000
LOG_LEVEL=debug

# MCP Servers Configuration
MCP_SERVER_TIMEOUT=30000
MCP_MAX_CONCURRENT_REQUESTS=10

# JD Parser MCP
MCP_JD_PARSER_ENDPOINT=http://localhost:8001
MCP_JD_PARSER_TIMEOUT=30

# Resume Analyzer MCP
MCP_RESUME_ANALYZER_ENDPOINT=http://localhost:8002
MCP_RESUME_ANALYZER_TIMEOUT=30

# Job Matcher MCP
MCP_JOB_MATCHER_ENDPOINT=http://localhost:8003
MCP_JOB_MATCHER_TIMEOUT=30

# Interview Prep MCP
MCP_INTERVIEW_PREP_ENDPOINT=http://localhost:8004
MCP_INTERVIEW_PREP_TIMEOUT=30

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_MOCK=true

# Email (optional) - For sending notifications and reports
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@synchire.com
EMAIL_REPLY_TO=support@synchire.com

# OAuth (optional) - For social login
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret

# Get credentials from: https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=your_github_oauth_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_client_secret

# Frontend OAuth URLs (automatically configured)
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
NEXT_PUBLIC_GITHUB_OAUTH_CLIENT_ID=your_github_oauth_client_id

# File Upload Settings
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx
ALLOWED_RESUME_TYPES=pdf,doc,docx

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Pagination Defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Application Settings
SESSION_SECRET=change_this_to_random_string
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
