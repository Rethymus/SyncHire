# SyncHire AI Prompt Testing - Environment Variables

# OpenAI API Key (for GPT-4o)
OPENAI_API_KEY=sk-...

# Anthropic API Key (for Claude)
ANTHROPIC_API_KEY=sk-ant-...

# LangSmith API Key (for tracing and evaluation)
LANGCHAIN_API_KEY=lsv2_...

# LangSmith Project Name
LANGCHAIN_PROJECT=synchire-prompt-testing

# LangSmith Endpoint (optional, for custom deployments)
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Optional: Set custom base URLs
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
