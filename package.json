{
  "name": "synchire",
  "version": "0.1.2",
  "private": true,
  "description": "AI-powered job application platform with MCP integration",
  "workspaces": [
    "frontend",
    "mcp-servers/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:api\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:api": "uvicorn main:app --reload --app-dir api --host 0.0.0.0 --port 8000",
    "dev:mcp": "./scripts/mcp-start.sh",
    "stop:mcp": "./scripts/mcp-stop.sh",
    "build": "npm run build --workspaces",
    "build:static": "node scripts/build-static.mjs",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:build:debug": "tauri build --debug",
    "desktop:build:linux": "tauri build --bundles deb",
    "desktop:build:linux:debug": "tauri build --debug --bundles deb",
    "desktop:build:win": "tauri build --bundles nsis",
    "desktop:build:win:debug": "tauri build --debug --bundles nsis",
    "android:add": "cap add android && node scripts/strip-capacitor-flatdir.mjs",
    "android:sync": "npm run build:static && cap sync android && node scripts/strip-capacitor-flatdir.mjs",
    "android:open": "cap open android",
    "android:run": "npm run android:sync && cap run android",
    "android:build:debug": "npm run android:sync && cd android && ./gradlew assembleDebug",
    "android:build:release": "npm run android:sync && cd android && ./gradlew assembleRelease",
    "test": "npm run --workspaces --if-present test",
    "lint": "npm run --workspaces --if-present lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:migrate": "./scripts/migrate.sh",
    "db:seed": "npm run db:seed --workspace=api",
    "db:reset": "./scripts/reset-db.sh",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "setup": "./scripts/dev.sh",
    "clean": "make clean"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@capacitor/cli": "^8.4.0",
    "@tauri-apps/cli": "^2.11.2",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vitest/ui": "^4.1.8",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.4",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "esbuild": "^0.28.0",
    "postcss": "^8.5.15",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@swc/helpers": "0.5.23",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@types/react-big-calendar": "^1.16.3",
    "date-fns": "^4.3.0",
    "next-intl": "^4.12.0",
    "react-big-calendar": "^1.19.4",
    "recharts": "^3.8.1"
  }
}
