{
  "name": "@synchire/mcp-job-matcher",
  "version": "1.0.0",
  "description": "MCP server for calculating job match scores between resumes and job descriptions",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "mcp-job-matcher": "build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "job-matching",
    "resume",
    "job-description",
    "hr",
    "recruiting"
  ],
  "author": "SyncHire",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
